{
  "uid": "xaf-app-performance",
  "title": "Application Performance",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests/sec",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(http_request_duration_seconds_count[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory (Working Set)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "process_working_set_bytes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(process_cpu_seconds_total[5m]) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "EF Core Avg Query Duration",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(ef_query_duration_seconds_sum[5m]) / rate(ef_query_duration_seconds_count[5m])",
          "refId": "A"
        }
      ]
    }
  ]
}
