{
  "uid": "xaf-business-activity",
  "title": "Business Activity",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CRUD Operations/min",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops/min"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(xaf_object_crud_total[5m])) by (entity, operation) * 60",
          "legendFormat": "{{entity}} - {{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Customer Creates",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "xaf_object_crud_total{entity=\"Customer\",operation=\"Create\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Order Creates",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "xaf_object_crud_total{entity=\"Order\",operation=\"Create\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Operations by Type",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(xaf_object_crud_total[5m])) by (operation) * 60",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    }
  ]
}
